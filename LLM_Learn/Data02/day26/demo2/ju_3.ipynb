   "cell_type": "code",
   "source": [
    "import pandas as pd\n",
    "\n",
    "s1 = pd.Series({\"a\": -1.2, \"b\": 3.5, \"c\": 6.8, \"d\": 2.9})\n",
    "\n",
    "data = s1 > s1.mean()\n",
    "\n",
    "print(data)\n",
    "print(type(data))\n",
    "\n"
   ],
   "id": "245b52e1c7236f1d",
